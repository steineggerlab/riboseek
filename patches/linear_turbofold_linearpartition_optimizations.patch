+    void logPlusAlpha(std::unordered_map<int, State> &beamstep, int key, float value, unsigned activeGeneration) {
+        if (activeGeneration != 0 && key >= 0 && static_cast<unsigned>(key) < seqLength) {
+            const std::size_t idx = static_cast<std::size_t>(key);
+            if (LP_LIKELY(generations[idx] == activeGeneration)) {
