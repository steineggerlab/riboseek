+        std::pair<std::unordered_map<int, State>::iterator, bool> inserted = beamstep.try_emplace(key, value);
+        if (!inserted.second) {
+            lpLogPlusEquals(inserted.first->second.alpha, value);
+        }
+        lpDenseAlphaPtrs[idx] = &inserted.first->second;
+        lpDenseAlphaGenerations[idx] = denseGeneration;
+        return;
