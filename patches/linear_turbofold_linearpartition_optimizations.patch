+struct LpAlphaCacheEntry {
+    const std::unordered_map<int, State> *map;
+    int key;
+    State *state;
+    unsigned generation;
+
+    LpAlphaCacheEntry() : map(NULL), key(0), state(NULL), generation(0) {}
+};
+
+static const std::size_t lpAlphaCacheSize = 1u << 16;
+static thread_local std::vector<LpAlphaCacheEntry> lpAlphaCache;
+static thread_local unsigned lpAlphaCacheGeneration = 0;
+
+static inline unsigned lpBeginAlphaCacheGeneration() {
+    if (lpAlphaCache.empty()) {
+        lpAlphaCache.resize(lpAlphaCacheSize);
+    }
+    ++lpAlphaCacheGeneration;
+    if (lpAlphaCacheGeneration == 0) {
+        for (LpAlphaCacheEntry &entry : lpAlphaCache) {
+            entry.generation = 0;
+        }
+        lpAlphaCacheGeneration = 1;
+    }
+    return lpAlphaCacheGeneration;
+}
+
+static inline void lpLogPlusAlphaCached(std::unordered_map<int, State> &beamstep, int key, float value, unsigned generation) {
+    const std::uintptr_t mapBits = reinterpret_cast<std::uintptr_t>(&beamstep) >> 4;
+    const std::size_t idx = (mapBits ^ (static_cast<unsigned>(key) * 2654435761u)) & (lpAlphaCacheSize - 1);
+    LpAlphaCacheEntry &entry = lpAlphaCache[idx];
+    if (entry.generation == generation && entry.map == &beamstep && entry.key == key) {
+        lpLogPlusEquals(entry.state->alpha, value);
+        return;
+    }
+
+    std::pair<std::unordered_map<int, State>::iterator, bool> inserted = beamstep.emplace(key, value);
+    if (!inserted.second) {
+        lpLogPlusEquals(inserted.first->second.alpha, value);
+    }
+    entry.map = &beamstep;
+    entry.key = key;
+    entry.state = &inserted.first->second;
+    entry.generation = generation;
+}
