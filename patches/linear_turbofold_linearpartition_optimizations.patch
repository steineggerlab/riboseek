+    ++lpDenseAlphaGeneration;
+    if (lpDenseAlphaGeneration == 0) {
+        std::fill(lpDenseAlphaGenerations.begin(), lpDenseAlphaGenerations.end(), 0);
+        lpDenseAlphaGeneration = 1;
+    }
+    const unsigned generation = lpDenseAlphaGeneration;
+    for (unsigned q = 0; q < seqLength; ++q) {
+        for (std::unordered_map<int, State>::iterator it = pfscore[q].begin(); it != pfscore[q].end(); ++it) {
